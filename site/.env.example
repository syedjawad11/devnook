# DevNook Agent Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.

# ── Anthropic (Claude Sonnet 4, Claude Haiku 3.5) ──────────────────────────
# Required for: frontend_dev, tool_builder, writer, qa task types
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Google AI (Gemini 2.5 Flash) ───────────────────────────────────────────
# Required for: keyword, planner, seo, analytics task types
GEMINI_API_KEY=your-gemini-api-key-here

# ── Google Service Account (Publishing / GSC Indexing API) ─────────────────
# Optional — only needed for Stage 6+ publishing pipeline
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── DEPRECATED — DO NOT USE ────────────────────────────────────────────────
# OpenRouter is no longer used. Remove from .env if present.
# OPENROUTER_API_KEY=
