---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allBlogPosts = await getCollection('blog');
const allGuides = await getCollection('guides');
const allLangPosts = await getCollection('languages');

type CombinedPost = {
  title: string;
  description: string;
  tags: string[];
  date: string;
  href: string;
  filterCat: string;
};

const combinedPosts: CombinedPost[] = [
  ...allBlogPosts.map(p => ({
    title: p.data.title,
    description: p.data.description,
    tags: p.data.tags,
    date: p.data.published_date,
    href: `/blog/${p.slug}/`,
    filterCat: 'blog',
  })),
  ...allGuides.map(p => ({
    title: p.data.title,
    description: p.data.description,
    tags: p.data.tags,
    date: p.data.published_date,
    href: `/guides/${p.slug}/`,
    filterCat: 'guides',
  })),
  ...allLangPosts.map(p => ({
    title: p.data.title,
    description: p.data.description,
    tags: p.data.tags,
    date: p.data.published_date,
    href: `/languages/${p.data.language}/${p.data.concept}/`,
    filterCat: 'languages',
  })),
];

const sortedPosts = combinedPosts.sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const [featured, ...rest] = sortedPosts;

const FILTERS = [
  { label: 'All',               key: 'all' },
  { label: 'Comparisons',       key: 'blog' },
  { label: 'AI & Productivity', key: 'ai' },
  { label: 'Tutorials',         key: 'languages' },
  { label: 'How-tos',           key: 'guides' },
];

function formatMonth(dateStr?: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return '';
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const pageTitle = 'Blog — DevNook';
const pageDescription = 'In-depth comparisons, tutorials, and insights on programming languages, frameworks, and developer tools.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="blog-index">
    <div class="container">
      <header class="page-header">
        <h1>Blog</h1>
        <p class="page-description">
          In-depth comparisons, tutorials, and insights on programming languages, frameworks, and developer tools.
        </p>
      </header>

      {sortedPosts.length > 0 && (
        <>
          <div class="filters" role="group" aria-label="Filter posts">
            {FILTERS.map((f, i) => (
              <button
                type="button"
                class={`chip ${i === 0 ? 'active' : ''}`}
                data-filter={f.key}
              >{f.label}</button>
            ))}
          </div>

          {featured && (
            <a
              class="featured"
              href={featured.href}
              data-post-item
              data-filter-cat={featured.filterCat}
              data-tags={featured.tags.join(',')}
            >
              <div class="featured-thumb" aria-hidden="true">
                <span class="thumb-mark">{(featured.title ?? '').charAt(0)}</span>
              </div>
              <div class="featured-body">
                <div class="featured-meta">
                  <span class="pill">Featured</span>
                  <span class="featured-date">{formatMonth(featured.date)}</span>
                </div>
                <h2>{featured.title}</h2>
                <p>{featured.description}</p>
                <span class="read-more">Read article &rarr;</span>
              </div>
            </a>
          )}

          {rest.length > 0 && (
            <div class="posts-grid">
              {rest.map((post) => (
                <div data-post-item data-filter-cat={post.filterCat} data-tags={post.tags.join(',')}>
                  <PostCard
                    title={post.title}
                    description={post.description}
                    href={post.href}
                    tags={post.tags}
                    date={post.date}
                    category={post.filterCat}
                  />
                </div>
              ))}
            </div>
          )}

          <p class="no-results" hidden>No posts match this filter.</p>
        </>
      )}

      {sortedPosts.length === 0 && (
        <div class="empty-state">
          <p>No blog posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </main>
</BaseLayout>

<script>
  const AI_TAGS = ['ai', 'llm', 'gpt', 'chatgpt', 'gemini', 'claude', 'openai', 'machine-learning', 'productivity'];

  const chips = document.querySelectorAll<HTMLButtonElement>('.chip[data-filter]');
  const postItems = document.querySelectorAll<HTMLElement>('[data-post-item]');
  const noResults = document.querySelector<HTMLElement>('.no-results');

  function isAiPost(el: HTMLElement): boolean {
    const tags = (el.dataset.tags ?? '').toLowerCase().split(',');
    const cat = el.dataset.filterCat ?? '';
    return tags.some(t => AI_TAGS.includes(t.trim())) || cat === 'ai';
  }

  function filterPosts(key: string) {
    let visible = 0;
    postItems.forEach(el => {
      const cat = el.dataset.filterCat ?? '';
      let show = false;
      if (key === 'all') {
        show = true;
      } else if (key === 'ai') {
        show = isAiPost(el);
      } else {
        show = cat === key;
      }
      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (noResults) noResults.hidden = visible > 0;
  }

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      filterPosts(chip.dataset.filter ?? 'all');
    });
  });
</script>

<style>
  .blog-index {
    padding: var(--space-6) 0;
    min-height: 60vh;
  }

  .container {
    max-width: var(--max-w-site);
    margin: 0 auto;
    padding: 0 var(--space-5);
  }

  .page-header {
    margin-bottom: var(--space-6);
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
    letter-spacing: -0.02em;
  }

  .page-description {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 300;
  }

  .filters {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .chip {
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-size: 13px;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .chip:hover:not(.active) {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }

  .chip.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-text-inv);
  }

  .featured {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    text-decoration: none;
    margin-bottom: var(--space-6);
    transition: all var(--transition-fast);
  }

  .featured:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  .featured-thumb {
    background: linear-gradient(135deg, var(--color-accent), var(--color-purple));
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 180px;
  }

  .thumb-mark {
    font-size: 4rem;
    font-weight: 700;
    color: var(--color-text-inv);
    font-family: var(--font-mono);
    opacity: 0.9;
  }

  .featured-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-1);
  }

  .pill {
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 12px;
    background: var(--color-accent-light);
    color: var(--color-accent-dark);
  }

  .featured-date {
    font-size: 12px;
    color: var(--color-text-faint);
    font-family: var(--font-mono);
  }

  .featured-body h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .featured-body p {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
    flex: 1;
  }

  .read-more {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-accent);
    margin-top: var(--space-2);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-4);
  }

  .no-results {
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-6) 0;
    font-size: 1rem;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-8) var(--space-4);
    color: var(--color-text-muted);
  }

  .empty-state p {
    font-size: 1.125rem;
  }

  @media (max-width: 768px) {
    .featured {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .featured-thumb {
      min-height: 140px;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
