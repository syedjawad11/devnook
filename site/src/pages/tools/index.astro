---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');

// Extract unique categories from tools
const categories = ['all', ...new Set(tools.map(tool => tool.data.category || 'other'))];

const pageTitle = 'Free Developer Tools — DevNook';
const pageDescription = 'Browser-based developer tools for JSON formatting, base64 encoding, JWT decoding, and more. No installation required.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="tools-page">
    <header class="tools-header">
      <h1>Developer Tools</h1>
      <p class="tools-subtitle">
        Free, privacy-friendly browser tools. No data leaves your device.
      </p>
    </header>

    {tools.length > 0 ? (
      <>
        <div class="filter-bar">
          <span class="filter-label">Filter:</span>
          <div class="filter-buttons" role="group" aria-label="Tool category filters">
            {categories.map(category => (
              <button
                class="filter-btn"
                data-category={category}
                aria-pressed={category === 'all' ? 'true' : 'false'}
              >
                {category === 'all' ? 'All Tools' : category.charAt(0).toUpperCase() + category.slice(1)}
              </button>
            ))}
          </div>
        </div>

        <div class="tools-grid">
          {tools.map(tool => (
            <ToolCard
              slug={tool.data.tool_slug ?? tool.slug}
              name={tool.data.title}
              description={tool.data.description}
              tier="client-side"
              icon="{ }"
            />
          ))}
        </div>
      </>
    ) : (
      <div class="empty-state">
        <div class="empty-icon" aria-hidden="true">🛠️</div>
        <h2>Tools Coming Soon</h2>
        <p>
          We're building a collection of free, privacy-focused developer tools.
          Check back soon for JSON formatters, encoders, decoders, and more.
        </p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .tools-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
  }

  .tools-header {
    text-align: center;
    margin-bottom: var(--space-7);
  }

  .tools-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
    letter-spacing: -0.02em;
  }

  .tools-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .filter-buttons {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-btn:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
    background: var(--color-accent-light);
  }

  .filter-btn[aria-pressed="true"] {
    color: var(--color-text-inv);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-4);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-8) var(--space-4);
    max-width: 500px;
    margin: 0 auto;
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: var(--space-4);
    opacity: 0.5;
  }

  .empty-state h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }

  .empty-state p {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .tools-page {
      padding: var(--space-5) var(--space-3);
    }

    .tools-header h1 {
      font-size: 2rem;
    }

    .tools-subtitle {
      font-size: 1rem;
    }

    .filter-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }

    .filter-buttons {
      width: 100%;
    }

    .filter-btn {
      flex: 1;
      min-width: 0;
    }

    .tools-grid {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .empty-icon {
      font-size: 3rem;
    }

    .empty-state h2 {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // Client-side filtering
  const filterButtons = document.querySelectorAll('.filter-btn');
  const toolCards = document.querySelectorAll('[data-tool-category]');

  function filterTools(category: string) {
    toolCards.forEach(card => {
      const toolCategory = card.getAttribute('data-tool-category');
      if (category === 'all' || toolCategory === category) {
        (card as HTMLElement).style.display = '';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });

    // Update button states
    filterButtons.forEach(btn => {
      const btnCategory = btn.getAttribute('data-category');
      btn.setAttribute('aria-pressed', btnCategory === category ? 'true' : 'false');
    });
  }

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const category = button.getAttribute('data-category');
      if (category) {
        filterTools(category);
      }
    });
  });
</script>