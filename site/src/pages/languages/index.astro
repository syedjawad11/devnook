---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LanguageCard from '../../components/LanguageCard.astro';
import { getCollection } from 'astro:content';
import { LANGUAGE_NAMES } from '../../lib/language-colors';

const allLanguagePosts = await getCollection('languages');

const languages = Object.keys(LANGUAGE_NAMES).map(slug => ({
  slug,
  name: LANGUAGE_NAMES[slug],
  postCount: allLanguagePosts.filter(p => p.data.language === slug).length,
}));
---

<BaseLayout
  title="Programming Languages — DevNook"
  description="Learn programming concepts across 12 popular languages: Python, JavaScript, TypeScript, Go, Rust, Java, C#, PHP, Ruby, Swift, Kotlin, and C++."
>
  <div class="languages-index">
    <header class="page-header">
      <h1>Programming Languages</h1>
      <p class="subtitle">
        Deep-dive tutorials and concept guides across {languages.length} popular programming languages.
      </p>
    </header>

    <div class="languages-grid">
      {languages.map(lang => (
        <LanguageCard
          language={lang.slug}
          displayName={lang.name}
          postCount={lang.postCount}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .languages-index {
    max-width: var(--max-w-site);
    margin: 0 auto;
    padding: var(--space-6) var(--space-5);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-7);
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 300;
  }

  .languages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-3);
  }

  @media (max-width: 520px) {
    .languages-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
