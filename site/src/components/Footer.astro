---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="inner">
    <div class="col col-brand">
      <a href="/" class="brand">
        <span class="logo-mark">D</span>
        <span class="brand-text">DevNook</span>
      </a>
      <p class="about">
        Free developer tools, guides, and cheat sheets for the modern web.
        A quiet corner of the internet, built to help you ship better code.
      </p>
      <span class="email-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <!--email_off-->admin@devnook.dev<!--/email_off-->
      </span>
    </div>

    <div class="col">
      <h4>Tools</h4>
      <ul>
        <li><a href="/tools/json-formatter/">JSON Formatter</a></li>
        <li><a href="/tools/regex-tester/">Regex Tester</a></li>
        <li><a href="/tools/base64-encoder/">Base64 Encoder</a></li>
        <li><a href="/tools/jwt-decoder/">JWT Decoder</a></li>
        <li><a href="/tools/">All tools &rarr;</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Languages</h4>
      <ul>
        <li><a href="/languages/python/">Python</a></li>
        <li><a href="/languages/javascript/">JavaScript</a></li>
        <li><a href="/languages/typescript/">TypeScript</a></li>
        <li><a href="/languages/go/">Go</a></li>
        <li><a href="/languages/">All languages &rarr;</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Resources</h4>
      <ul>
        <li><a href="/cheatsheets/">Cheatsheets</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/guides/">Guides</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Site</h4>
      <ul>
        <li><a href="/about/">About</a></li>
        <li><a href="/cookie-policy/">Cookie Policy</a></li>
      </ul>
    </div>
  </div>

  <div class="bottom">
    <span>&copy; {currentYear} DevNook. All rights reserved.</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-8);
    padding: var(--space-7) var(--space-5) var(--space-5);
    background: var(--color-surface);
  }

  .inner {
    max-width: var(--max-w-site);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: var(--space-6);
  }

  .col h4 {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-faint);
  }

  .col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .col li {
    margin-bottom: var(--space-2);
  }

  .col li a {
    font-size: 14px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .col li a:hover {
    color: var(--color-accent);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: var(--space-3);
  }

  .logo-mark {
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
  }

  .about {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 420px;
  }

  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--space-3);
    font-size: 14px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .email-link {
    cursor: text;
    user-select: all;
  }

  .bottom {
    max-width: var(--max-w-site);
    margin: var(--space-6) auto 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: 12px;
    color: var(--color-text-faint);
  }

  @media (max-width: 900px) {
    .inner {
      grid-template-columns: 1fr 1fr;
    }

    .col-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 520px) {
    .inner {
      grid-template-columns: 1fr;
    }
  }
</style>
