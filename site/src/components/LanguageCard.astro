---
import { langColor } from '../lib/language-colors';

interface Props {
  language: string;
  displayName: string;
  postCount: number;
  featuredTopics?: string[];
}

const { language, displayName, postCount } = Astro.props;
const href = `/languages/${language}/`;
const dotColor = langColor(language);
---

<a href={href} class="lang-card">
  <span class="lang-dot" style={`background:${dotColor}`}></span>
  <span class="name">{displayName}</span>
  <span class="count">{postCount}</span>
</a>

<style>
  .lang-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .lang-card:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-light);
  }

  .lang-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .name {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
  }

  .count {
    font-size: 12px;
    color: var(--color-text-faint);
    margin-left: auto;
    font-family: var(--font-mono);
  }
</style>
