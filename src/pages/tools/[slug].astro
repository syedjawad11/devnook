---
import { getCollection } from 'astro:content';
import ToolLayout from '../../layouts/ToolLayout.astro';

const toolModules = import.meta.glob<{ default: any }>(
  '../../components/tools/*.astro',
  { eager: true }
);
const toolComponents: Record<string, any> = {};
for (const [path, mod] of Object.entries(toolModules)) {
  const slug = path.split('/').pop()!.replace('.astro', '');
  toolComponents[slug] = mod.default;
}

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  const availableSlugs = new Set(
    Object.keys(
      import.meta.glob('../../components/tools/*.astro', { eager: true })
    ).map((p) => p.split('/').pop()!.replace('.astro', ''))
  );
  return tools
    .filter((tool) => availableSlugs.has(tool.data.tool_slug ?? tool.slug))
    .map((tool) => ({
      params: { slug: tool.data.tool_slug ?? tool.slug },
      props: { tool },
    }));
}

const { tool } = Astro.props;
const allToolEntries = await getCollection('tools');
const validToolPaths = new Set(
  allToolEntries.map((t) => `/tools/${t.data.tool_slug ?? t.slug}`)
);
const filteredRelatedTools = (tool.data.related_tools ?? []).filter(
  (path: string) => validToolPaths.has(path)
);
const { Content } = await tool.render();

const ToolComponent = toolComponents[tool.data.tool_slug ?? tool.slug];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools/' },
  { label: tool.data.title, href: `/tools/${tool.slug}` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.data.title,
  description: tool.data.description,
  applicationCategory: 'WebApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  aggregateRating:
    tool.data.tier === 'tier-1'
      ? {
          '@type': 'AggregateRating',
          ratingValue: '4.8',
          ratingCount: '150',
        }
      : undefined,
};

const cheatsheetLink = tool.data.related_content?.find((c: string) =>
  c.startsWith('/cheatsheets/')
);
---

<ToolLayout
  title={tool.data.title}
  description={tool.data.description}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="tool-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        {
          breadcrumbs.map((crumb, i) => (
            <li>
              {i < breadcrumbs.length - 1 ? (
                <>
                  <a href={crumb.href}>{crumb.label}</a>
                  <span class="separator">/</span>
                </>
              ) : (
                <span aria-current="page">{crumb.label}</span>
              )}
            </li>
          ))
        }
      </ol>
    </nav>

    <header class="tool-header">
      <h1>{tool.data.title}</h1>
      <p class="tool-description">{tool.data.description}</p>
    </header>

    <div class="tool-workspace">
      <main class="tool-main">
        <div class="tool-widget-card">
          <ToolComponent />
        </div>

        <article class="prose">
          <Content />
        </article>
      </main>

      <aside class="tool-sidebar">
        <div class="sidebar-card info-box">
          <h2>About this tool</h2>
          {tool.data.tier && (
            <span class={`tier-badge tier-${tool.data.tier}`}>
              {tool.data.tier === 'tier-1' ? 'Popular' : tool.data.tier === 'tier-2' ? 'Standard' : 'Utility'}
            </span>
          )}
          <p>{tool.data.description}</p>
        </div>

        {filteredRelatedTools.length > 0 && (
          <div class="sidebar-card">
            <h2>Related tools</h2>
            <ul class="related-list">
              {filteredRelatedTools.map((relatedPath: string) => {
                const slug = relatedPath.split('/').pop();
                return (
                  <li>
                    <a href={relatedPath} class="related-link">
                      {slug?.replace(/-/g, ' ')}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}

        {cheatsheetLink && (
          <div class="sidebar-card cheatsheet-card">
            <h2>Cheat sheet</h2>
            <a href={cheatsheetLink} class="cheatsheet-link">
              View reference cheat sheet →
            </a>
          </div>
        )}
      </aside>
    </div>
  </div>
</ToolLayout>

<style>
  .tool-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
  }

  /* Breadcrumb */
  .breadcrumb {
    margin-bottom: var(--space-4);
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb .separator {
    color: var(--color-border);
  }

  .breadcrumb [aria-current='page'] {
    color: var(--color-text);
  }

  /* Header */
  .tool-header {
    margin-bottom: var(--space-6);
  }

  .tool-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-3) 0;
    line-height: 1.2;
  }

  .tool-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* Workspace 2-col grid */
  .tool-workspace {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: var(--space-6);
    align-items: start;
  }

  /* Main column */
  .tool-widget-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }

  /* Prose content */
  .prose {
    color: var(--color-text);
  }

  .prose :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin: var(--space-6) 0 var(--space-4) 0;
    line-height: 1.3;
  }

  .prose :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-text);
    margin: var(--space-5) 0 var(--space-3) 0;
    line-height: 1.4;
  }

  .prose :global(h4) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin: var(--space-4) 0 var(--space-3) 0;
    line-height: 1.4;
  }

  .prose :global(p) {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 0 0 var(--space-4) 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 var(--space-4) 0;
    padding-left: var(--space-5);
  }

  .prose :global(li) {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: var(--space-2);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface);
    padding: 0.125em 0.375em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
    margin: 0 0 var(--space-4) 0;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .prose :global(a:hover) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-4);
    margin: var(--space-4) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-4) 0;
    font-size: 0.9375rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .prose :global(th) {
    background: var(--color-surface);
    font-weight: 600;
    color: var(--color-text);
  }

  /* Sidebar */
  .tool-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: sticky;
    top: var(--space-6);
  }

  .sidebar-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .sidebar-card h2 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 var(--space-3) 0;
  }

  .sidebar-card p {
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: var(--space-2) 0 0 0;
  }

  .tier-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25em 0.625em;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-2);
  }

  .tier-tier-1 {
    background: var(--color-green-light);
    color: var(--color-green);
  }

  .tier-tier-2 {
    background: var(--color-surface);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .tier-tier-3 {
    background: var(--color-surface);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .related-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    text-decoration: none;
    text-transform: capitalize;
    font-size: 0.9375rem;
    transition: all 0.2s ease;
  }

  .related-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .cheatsheet-link {
    display: block;
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .cheatsheet-link:hover {
    text-decoration: underline;
  }

  /* Responsive — collapse to 1-col at 900px */
  @media (max-width: 900px) {
    .tool-workspace {
      grid-template-columns: 1fr;
    }

    .tool-sidebar {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .tool-page {
      padding: var(--space-4) var(--space-3);
    }

    .tool-header h1 {
      font-size: 2rem;
    }

    .tool-description {
      font-size: 1rem;
    }

    .tool-widget-card {
      padding: var(--space-4);
    }

    .prose :global(h2) {
      font-size: 1.5rem;
    }

    .prose :global(h3) {
      font-size: 1.25rem;
    }
  }
</style>
