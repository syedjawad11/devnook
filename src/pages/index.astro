---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import LanguageCard from '../components/LanguageCard.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { LANGUAGE_NAMES } from '../lib/language-colors';

const allLangPosts = await getCollection('languages');
const allGuides = await getCollection('guides');
const allBlogPosts = await getCollection('blog');
const allCheatsheets = await getCollection('cheatsheets');
const allTools = await getCollection('tools');

const combinedRecent = [
  ...allLangPosts.map(p => ({
    ...p,
    href: `/languages/${p.data.language}/${p.data.concept}/`,
  })),
  ...allGuides.map(p => ({ ...p, href: `/guides/${p.slug}/` })),
  ...allBlogPosts.map(p => ({ ...p, href: `/blog/${p.slug}/` })),
];

const recentPosts = combinedRecent
  .sort((a, b) => new Date(b.data.published_date).getTime() - new Date(a.data.published_date).getTime())
  .slice(0, 6);

const FEATURED_TOOL_SLUGS = ['json-formatter', 'base64-encoder', 'regex-tester', 'jwt-decoder'];
const featuredTools = FEATURED_TOOL_SLUGS
  .map(slug => allTools.find(t => (t.data.tool_slug ?? t.slug) === slug))
  .filter(Boolean) as typeof allTools;

const TOOL_ICONS: Record<string, string> = {
  'json-formatter': '{ }',
  'base64-encoder': 'B64',
  'regex-tester': '.*',
  'jwt-decoder': 'JWT',
  'uuid-generator': 'ID',
  'hash-generator': '#',
  'url-encoder': '%',
  'sql-formatter': 'SQL',
  'markdown-to-html': 'MD',
  'csv-to-json': 'CSV',
};

const LANGUAGE_SLUGS = Object.keys(LANGUAGE_NAMES);
const languages = LANGUAGE_SLUGS.map(slug => ({
  slug,
  name: LANGUAGE_NAMES[slug],
  postCount: allLangPosts.filter(p => p.data.language === slug).length,
}));

const cheatsheetsSorted = allCheatsheets
  .sort((a, b) => new Date(b.data.published_date).getTime() - new Date(a.data.published_date).getTime())
  .slice(0, 8);

const HERO_TAGS = [
  { label: 'Python', href: '/languages/python/' },
  { label: 'JSON Formatter', href: '/tools/json-formatter/' },
  { label: 'Regex Tester', href: '/tools/regex-tester/' },
  { label: 'JWT Decoder', href: '/tools/jwt-decoder/' },
  { label: 'Base64 Encoder', href: '/tools/base64-encoder/' },
];
---

<BaseLayout
  title="DevNook — Developer Resources, Fast"
  description="Free developer tools, guides, and cheat sheets for the modern web. No ads, no tracking, just the information you need."
>
  <div class="hero">
    <h1>Developer tools, guides,<br>and <span class="gradient">cheat sheets</span></h1>
    <p>Free browser-based tools, language guides, and quick-reference cheat sheets. No ads, no tracking, just the information you need.</p>
    <div class="hero-tags">
      {HERO_TAGS.map(tag => (
        <a class="hero-tag" href={tag.href}>{tag.label}</a>
      ))}
    </div>
  </div>

  <section class="section">
    <div class="section-head">
      <h2>Popular tools</h2>
      <a href="/tools/" class="section-link">View all tools &rarr;</a>
    </div>
    <div class="tools-grid">
      {featuredTools.map(tool => (
        <ToolCard
          slug={tool.data.tool_slug ?? tool.slug}
          name={tool.data.title}
          description={tool.data.description}
          tier="client-side"
          icon={TOOL_ICONS[tool.data.tool_slug ?? tool.slug] ?? '{ }'}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Browse by language</h2>
      <a href="/languages/" class="section-link">See all languages &rarr;</a>
    </div>
    <div class="lang-grid">
      {languages.map(lang => (
        <LanguageCard
          language={lang.slug}
          displayName={lang.name}
          postCount={lang.postCount}
        />
      ))}
    </div>
  </section>

  {cheatsheetsSorted.length > 0 && (
    <section class="section">
      <div class="section-head">
        <h2>Trending cheat sheets</h2>
        <a href="/cheatsheets/" class="section-link">All cheat sheets &rarr;</a>
      </div>
      <div class="cs-strip">
        {cheatsheetsSorted.map(cs => (
          <a class="cs-card" href={`/cheatsheets/${cs.slug}/`}>
            <h4>{cs.data.title}</h4>
            <p>{cs.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section class="section">
      <div class="section-head">
        <h2>Latest from the blog</h2>
        <a href="/blog/" class="section-link">All posts &rarr;</a>
      </div>
      <div class="posts-grid">
        {recentPosts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            href={post.href}
            tags={post.data.tags}
            date={post.data.published_date}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: var(--space-8) var(--space-5) var(--space-7);
    text-align: center;
    background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-bg) 100%);
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    max-width: 700px;
    margin: 0 auto var(--space-4);
    color: var(--color-text);
  }

  .hero .gradient {
    background: linear-gradient(135deg, var(--color-accent), var(--color-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto var(--space-6);
    font-weight: 300;
  }

  .hero-tags {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-tag {
    padding: 6px 14px;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    font-size: 13px;
    color: var(--color-text-muted);
    background: var(--color-surface);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .hero-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-dark);
    background: var(--color-accent-light);
  }

  .section {
    max-width: var(--max-w-site);
    margin: 0 auto;
    padding: var(--space-6) var(--space-5);
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-5);
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .section-head h2 {
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }

  .section-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
  }

  .section-link:hover {
    color: var(--color-accent-dark);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-3);
  }

  .lang-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: var(--space-3);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-4);
  }

  .cs-strip {
    display: flex;
    gap: var(--space-3);
    overflow-x: auto;
    padding-bottom: var(--space-2);
    scroll-snap-type: x mandatory;
  }

  .cs-card {
    flex-shrink: 0;
    width: 220px;
    scroll-snap-align: start;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .cs-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .cs-card h4 {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 var(--space-1);
    color: var(--color-text);
    line-height: 1.3;
  }

  .cs-card p {
    font-size: 12px;
    color: var(--color-text-faint);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .tools-grid,
    .posts-grid {
      grid-template-columns: 1fr;
    }

    .lang-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
