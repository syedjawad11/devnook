---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import TagBadge from '../components/TagBadge.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    category: string;
    language?: string;
    concept?: string;
    tags?: string[];
    published_date: string;
    related_posts?: string[];
    og_image?: string;
  };
}

const { frontmatter } = Astro.props;

type RelatedItem = { title: string; slug: string; category: string };
const [allGuides, allBlog, allCheatsheets, allLanguages, allTools] = await Promise.all([
  getCollection('guides'),
  getCollection('blog'),
  getCollection('cheatsheets'),
  getCollection('languages'),
  getCollection('tools'),
]);
const pathMap = new Map<string, RelatedItem>();
for (const e of allGuides)
  pathMap.set(`/guides/${e.slug}`, { title: e.data.title, slug: `/guides/${e.slug}`, category: 'Guide' });
for (const e of allBlog)
  pathMap.set(`/blog/${e.slug}`, { title: e.data.title, slug: `/blog/${e.slug}`, category: 'Blog' });
for (const e of allCheatsheets)
  pathMap.set(`/cheatsheets/${e.slug}`, { title: e.data.title, slug: `/cheatsheets/${e.slug}`, category: 'Cheatsheet' });
for (const e of allLanguages)
  pathMap.set(`/languages/${e.slug}`, { title: e.data.title, slug: `/languages/${e.slug}`, category: e.data.language });
for (const e of allTools)
  pathMap.set(`/tools/${e.data.tool_slug ?? e.slug}`, { title: e.data.title, slug: `/tools/${e.data.tool_slug ?? e.slug}`, category: 'Tool' });
const resolvedRelatedPosts: RelatedItem[] = (frontmatter.related_posts ?? [])
  .map((path: string) => pathMap.get(path))
  .filter((item: RelatedItem | undefined): item is RelatedItem => item !== undefined);

const formattedDate = new Date(frontmatter.published_date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const breadcrumbItems: { label: string; href: string | null }[] = [
  { label: 'Home', href: '/' },
];
const pathParts = Astro.url.pathname.split('/').filter(Boolean);

if (pathParts.length > 0) {
  breadcrumbItems.push({ label: pathParts[0], href: `/${pathParts[0]}` });
}
if (pathParts.length > 1 && frontmatter.language) {
  breadcrumbItems.push({
    label: frontmatter.language,
    href: `/languages/${frontmatter.language}`
  });
}
breadcrumbItems.push({ label: frontmatter.title, href: null });
---

<BaseLayout 
  title={frontmatter.title} 
  description={frontmatter.description}
  ogImage={frontmatter.og_image}
>
  <article class="post-layout">
    <div class="container">
      <div class="post-header">
        <Breadcrumb crumbs={breadcrumbItems} />
        <h1>{frontmatter.title}</h1>
        <div class="meta-bar">
          <time datetime={frontmatter.published_date}>{formattedDate}</time>
          {frontmatter.tags && frontmatter.tags.length > 0 && (
            <div class="tags">
              {frontmatter.tags.map(tag => (
                <TagBadge tag={tag} />
              ))}
            </div>
          )}
        </div>
      </div>

      <div class="post-content-wrapper">
        <main class="prose">
          <slot />
        </main>

        <aside class="sidebar">
          <div class="toc-container">
            <h2>Table of Contents</h2>
            <nav class="toc" id="toc"></nav>
          </div>
        </aside>
      </div>

      {resolvedRelatedPosts.length > 0 && (
        <div class="related-section">
          <RelatedPosts posts={resolvedRelatedPosts} />
        </div>
      )}
    </div>
  </article>

  <script>
    function generateTableOfContents() {
      const toc = document.getElementById('toc');
      if (!toc) return;

      const headings = document.querySelectorAll('.prose h2, .prose h3');
      if (headings.length === 0) {
        const container = toc.closest('.toc-container');
        if (container) container.style.display = 'none';
        return;
      }

      const tocList = document.createElement('ul');
      tocList.className = 'toc-list';

      headings.forEach((heading, index) => {
        const id = heading.id || `heading-${index}`;
        if (!heading.id) heading.id = id;

        const listItem = document.createElement('li');
        listItem.className = heading.tagName.toLowerCase() === 'h3' ? 'toc-item toc-item-h3' : 'toc-item';

        const link = document.createElement('a');
        link.href = `#${id}`;
        link.textContent = heading.textContent || '';
        link.className = 'toc-link';

        listItem.appendChild(link);
        tocList.appendChild(listItem);
      });

      toc.appendChild(tocList);

      // Smooth scroll
      const links = tocList.querySelectorAll('.toc-link');
      links.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetId = link.getAttribute('href')?.slice(1);
          if (!targetId) return;
          const target = document.getElementById(targetId);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.pushState(null, '', `#${targetId}`);
          }
        });
      });

      // Active state on scroll
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const id = entry.target.id;
          const tocLink = toc.querySelector(`a[href="#${id}"]`);
          if (tocLink) {
            if (entry.isIntersecting) {
              links.forEach(l => l.classList.remove('active'));
              tocLink.classList.add('active');
            }
          }
        });
      }, {
        rootMargin: '-100px 0px -66%'
      });

      headings.forEach(heading => observer.observe(heading));
    }

    document.addEventListener('DOMContentLoaded', generateTableOfContents);
  </script>
</BaseLayout>

<style>
  .post-layout {
    background: var(--color-bg);
    min-height: 100vh;
    padding: var(--space-6) 0 var(--space-8);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-4);
  }

  .post-header {
    margin-bottom: var(--space-6);
  }

  .post-header h1 {
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
    margin: var(--space-3) 0 var(--space-4);
  }

  .meta-bar {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .meta-bar time {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .post-content-wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .prose {
    max-width: 760px;
    color: var(--color-text);
    line-height: 1.7;
  }

  .prose :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
    scroll-margin-top: var(--space-5);
  }

  .prose :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
    scroll-margin-top: var(--space-5);
  }

  .prose :global(p) {
    margin-bottom: var(--space-4);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-5);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    color: var(--color-accent);
  }

  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
    margin-bottom: var(--space-4);
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: var(--color-text);
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: var(--color-accent);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: var(--space-4);
    margin: var(--space-4) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-4);
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--color-border);
    padding: var(--space-2) var(--space-3);
    text-align: left;
  }

  .prose :global(th) {
    background: var(--color-surface);
    font-weight: 600;
  }

  .sidebar {
    display: none;
  }

  .toc-container {
    position: sticky;
    top: calc(60px + var(--space-4));
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .toc-container h2 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }

  .toc :global(.toc-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc :global(.toc-item) {
    margin-bottom: var(--space-2);
  }

  .toc :global(.toc-item-h3) {
    padding-left: var(--space-3);
  }

  .toc :global(.toc-link) {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    text-decoration: none;
    padding: var(--space-1) 0;
    transition: color 0.2s;
  }

  .toc :global(.toc-link:hover) {
    color: var(--color-accent);
  }

  .toc :global(.toc-link.active) {
    color: var(--color-accent);
    font-weight: 500;
  }

  .related-section {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .post-header h1 {
      font-size: 2.75rem;
    }

    .post-content-wrapper {
      grid-template-columns: 1fr 280px;
      gap: var(--space-8);
    }

    .sidebar {
      display: block;
    }

    .prose :global(h2) {
      font-size: 2rem;
    }

    .prose :global(h3) {
      font-size: 1.5rem;
    }
  }
</style>