---
interface Props {
  name: string;
  description: string;
  slug: string;
  category?: string;
  tier: string;
  icon?: string;
}

const { name, description, slug, tier, icon = '' } = Astro.props;

const tierLabel = tier === 'free' ? 'Free' : tier === 'client-side' ? 'Client-side' : tier;

const ICON_PALETTE = [
  { color: 'var(--color-accent)', bg: 'var(--color-accent-light)' },
  { color: 'var(--color-purple)', bg: 'var(--color-purple-light)' },
  { color: 'var(--color-amber)',  bg: 'var(--color-amber-light)' },
  { color: 'var(--color-coral)',  bg: 'var(--color-coral-light)' },
  { color: 'var(--color-green)',  bg: 'var(--color-green-light)' },
];

function hashSlug(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0;
  return h;
}

const palette = ICON_PALETTE[hashSlug(slug) % ICON_PALETTE.length];
---

<article class="tool-card">
  <div class="icon-row">
    <div class="tool-icon" style={`background:${palette.bg}; color:${palette.color}`}>{icon || '{ }'}</div>
    <span class="tool-badge">{tierLabel}</span>
  </div>

  <h3 class="tool-name">
    <a href={`/tools/${slug}/`}>{name}</a>
  </h3>

  <p class="tool-description">{description}</p>
</article>

<style>
  .tool-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: border-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .tool-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  .icon-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .tool-icon {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
  }

  .tool-badge {
    font-size: 11px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 12px;
    background: var(--color-green-light);
    color: var(--color-green);
    white-space: nowrap;
  }

  .tool-name {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
  }

  .tool-name a {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .tool-name a:hover {
    color: var(--color-accent);
  }

  .tool-description {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }
</style>
