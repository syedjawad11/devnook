---
// Markdown to HTML Converter — Client-side only
---
<div class="tool-container" id="tool-markdown-to-html">
  <div class="tool-header">
    <h2>Markdown to HTML Converter</h2>
    <p class="tool-desc">Convert Markdown to clean HTML instantly in your browser with GitHub Flavored Markdown support.</p>
  </div>
  
  <div class="tool-controls">
    <div class="controls-group">
      <button type="button" id="convertBtn" class="btn btn-primary" aria-label="Convert Markdown to HTML">
        Convert
      </button>
      <button type="button" id="copyBtn" class="btn btn-secondary" aria-label="Copy HTML output to clipboard">
        Copy HTML
      </button>
      <button type="button" id="clearBtn" class="btn btn-secondary" aria-label="Clear all fields">
        Clear
      </button>
    </div>
    <div class="controls-group">
      <label for="viewMode" class="view-label">View:</label>
      <select id="viewMode" class="view-select" aria-label="Select view mode">
        <option value="split">Split</option>
        <option value="preview">Preview only</option>
        <option value="html">HTML only</option>
      </select>
    </div>
  </div>

  <div class="tool-body">
    <div class="input-section">
      <label for="markdownInput" class="input-label">Paste Markdown here</label>
      <textarea 
        id="markdownInput" 
        class="tool-textarea" 
        placeholder="# Hello World&#10;&#10;This is **bold** and this is *italic*.&#10;&#10;- List item 1&#10;- List item 2&#10;&#10;```javascript&#10;console.log('Hello');&#10;```"
        rows="16"
        aria-label="Markdown input"
        spellcheck="false"
      ></textarea>
    </div>
    
    <div class="output-section" id="outputSection">
      <div class="preview-pane" id="previewPane">
        <label class="output-label">Live Preview</label>
        <div id="previewOutput" class="preview-output" aria-live="polite"></div>
      </div>
      
      <div class="html-pane" id="htmlPane">
        <label for="htmlOutput" class="output-label">HTML output</label>
        <textarea 
          id="htmlOutput" 
          class="tool-textarea" 
          readonly
          rows="16"
          aria-label="HTML output"
          spellcheck="false"
        ></textarea>
      </div>
    </div>
  </div>

  <div class="tool-status" id="toolStatus" aria-live="polite"></div>
  <div class="tool-error" id="toolError" role="alert"></div>
</div>

<script>
(function() {
  'use strict';

  const markdownInput = document.getElementById('markdownInput');
  if (!markdownInput) return;

  // Minimal inline Markdown→HTML parser (no CDN needed)
  function parseMarkdown(md) {
    let html = md
      // Fenced code blocks
      .replace(/```(\w*)\n([\s\S]*?)```/g, (_, lang, code) =>
        `<pre><code${lang ? ` class="language-${lang}"` : ''}>${escMd(code.trimEnd())}</code></pre>`)
      // Headings
      .replace(/^(#{1,6})\s+(.+)$/gm, (_, h, t) => `<h${h.length}>${t}</h${h.length}>`)
      // Blockquotes
      .replace(/^>\s?(.+)$/gm, '<blockquote>$1</blockquote>')
      // Unordered lists (simplistic — single level)
      .replace(/^[-*+]\s+(.+)$/gm, '<li>$1</li>')
      // Ordered lists
      .replace(/^\d+\.\s+(.+)$/gm, '<li>$1</li>')
      // Horizontal rule
      .replace(/^---+$/gm, '<hr>')
      // Bold
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      // Italic
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      // Inline code
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      // Links
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
      // Images
      .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img alt="$1" src="$2">')
      // Wrap consecutive <li> in <ul>
      .replace(/(<li>.*<\/li>\n?)+/g, m => `<ul>${m}</ul>`)
      // Paragraphs: blank-line-separated blocks not already tagged
      .split(/\n{2,}/)
      .map(block => {
        const trimmed = block.trim();
        if (!trimmed) return '';
        if (/^<(h[1-6]|ul|ol|li|pre|blockquote|hr)/.test(trimmed)) return trimmed;
        return `<p>${trimmed.replace(/\n/g, '<br>')}</p>`;
      })
      .join('\n');
    return html;
  }

  function escMd(text) {
    return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }
  const htmlOutput = document.getElementById('htmlOutput');
  const previewOutput = document.getElementById('previewOutput');
  const convertBtn = document.getElementById('convertBtn');
  const copyBtn = document.getElementById('copyBtn');
  const clearBtn = document.getElementById('clearBtn');
  const viewModeSelect = document.getElementById('viewMode');
  const toolStatus = document.getElementById('toolStatus');
  const toolError = document.getElementById('toolError');
  const previewPane = document.getElementById('previewPane');
  const htmlPane = document.getElementById('htmlPane');
  const outputSection = document.getElementById('outputSection');

  function showStatus(message) {
    toolStatus.textContent = message;
    toolError.textContent = '';
    setTimeout(() => {
      toolStatus.textContent = '';
    }, 3000);
  }

  function showError(message) {
    toolError.textContent = message;
    toolStatus.textContent = '';
  }

  function clearMessages() {
    toolStatus.textContent = '';
    toolError.textContent = '';
  }

  function updateViewMode() {
    const mode = viewModeSelect.value;
    
    outputSection.classList.remove('view-split', 'view-preview', 'view-html');
    
    if (mode === 'split') {
      outputSection.classList.add('view-split');
      previewPane.style.display = 'block';
      htmlPane.style.display = 'block';
    } else if (mode === 'preview') {
      outputSection.classList.add('view-preview');
      previewPane.style.display = 'block';
      htmlPane.style.display = 'none';
    } else if (mode === 'html') {
      outputSection.classList.add('view-html');
      previewPane.style.display = 'none';
      htmlPane.style.display = 'block';
    }
  }

  function convertMarkdown() {
    clearMessages();
    
    const markdown = markdownInput.value.trim();
    
    if (!markdown) {
      showError('Please enter some Markdown text to convert.');
      htmlOutput.value = '';
      previewOutput.innerHTML = '';
      return;
    }

    try {
      const html = parseMarkdown(markdown);
      htmlOutput.value = html;
      previewOutput.innerHTML = html;
      showStatus('Markdown converted successfully!');
    } catch (error) {
      showError('Error converting Markdown: ' + (error.message || 'Unknown error occurred'));
      htmlOutput.value = '';
      previewOutput.innerHTML = '';
    }
  }

  function copyToClipboard() {
    const html = htmlOutput.value;
    
    if (!html) {
      showError('No HTML to copy. Please convert Markdown first.');
      return;
    }

    if (!navigator.clipboard) {
      showError('Clipboard API not supported in your browser.');
      return;
    }

    navigator.clipboard.writeText(html)
      .then(() => {
        const originalText = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        showStatus('HTML copied to clipboard!');
        
        setTimeout(() => {
          copyBtn.textContent = originalText;
        }, 2000);
      })
      .catch(() => {
        showError('Failed to copy HTML to clipboard.');
      });
  }

  function clearAll() {
    markdownInput.value = '';
    htmlOutput.value = '';
    previewOutput.innerHTML = '';
    clearMessages();
  }

  // Event listeners
  convertBtn.addEventListener('click', convertMarkdown);
  copyBtn.addEventListener('click', copyToClipboard);
  clearBtn.addEventListener('click', clearAll);
  viewModeSelect.addEventListener('change', updateViewMode);

  // Auto-convert on input (debounced)
  let debounceTimer;
  markdownInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      if (markdownInput.value.trim()) {
        convertMarkdown();
      }
    }, 500);
  });

  // Keyboard shortcuts
  markdownInput.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
      e.preventDefault();
      convertMarkdown();
    }
  });

  // Initialize view mode
  updateViewMode();
})();
</script>

<style>
.tool-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: var(--space-4);
}

.tool-header {
  margin-bottom: var(--space-4);
}

.tool-header h2 {
  font-family: var(--font-body);
  font-size: 1.75rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0 0 var(--space-2) 0;
}

.tool-desc {
  font-family: var(--font-body);
  color: var(--color-text-muted);
  margin: 0;
  font-size: 0.95rem;
}

.tool-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-4);
  flex-wrap: wrap;
}

.controls-group {
  display: flex;
  gap: var(--space-2);
  align-items: center;
}

.view-label {
  font-family: var(--font-body);
  color: var(--color-text);
  font-size: 0.9rem;
  margin: 0;
}

.view-select {
  font-family: var(--font-body);
  background: var(--color-surface);
  color: var(--color-text);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0.5rem 0.75rem;
  font-size: 0.9rem;
  cursor: pointer;
}

.view-select:hover {
  border-color: var(--color-accent);
}

.view-select:focus {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}

.btn {
  font-family: var(--font-body);
  padding: 0.5rem 1rem;
  border: none;
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-primary {
  background: var(--color-accent);
  color: var(--color-bg);
}

.btn-primary:hover {
  background: #5dd9a5;
}

.btn-primary:focus {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}

.btn-secondary {
  background: var(--color-surface);
  color: var(--color-text);
  border: 1px solid var(--color-border);
}

.btn-secondary:hover {
  border-color: var(--color-accent);
  background: var(--color-green-light);
}

.btn-secondary:focus {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}

.tool-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.input-section,
.output-section {
  display: flex;
  flex-direction: column;
}

.input-label,
.output-label {
  font-family: var(--font-body);
  color: var(--color-text);
  font-size: 0.9rem;
  font-weight: 500;
  margin-bottom: var(--space-2);
  display: block;
}

.tool-textarea {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  background: var(--color-surface);
  color: var(--color-text);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  resize: vertical;
  line-height: 1.6;
  width: 100%;
  box-sizing: border-box;
}

.tool-textarea:focus {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
  border-color: var(--color-accent);
}

.tool-textarea::placeholder {
  color: var(--color-text-muted);
  opacity: 0.6;
}

.output-section {
  gap: var(--space-4);
}

.output-section.view-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}

.preview-pane,
.html-pane {
  display: flex;
  flex-direction: column;
}

.preview-output {
  font-family: var(--font-body);
  font-size: 0.95rem;
  background: var(--color-surface);
  color: var(--color-text);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  min-height: 300px;
  overflow-y: auto;
  line-height: 1.6;
}

.preview-output h1,
.preview-output h2,
.preview-output h3,
.preview-output h4,
.preview-output h5,
.preview-output h6 {
  font-family: var(--font-body);
  color: var(--color-text);
  margin: var(--space-3) 0 var(--space-2) 0;
  font-weight: 600;
}

.preview-output h1 { font-size: 1.75rem; }
.preview-output h2 { font-size: 1.5rem; }
.preview-output h3 { font-size: 1.25rem; }
.preview-output h4 { font-size: 1.1rem; }
.preview-output h5 { font-size: 1rem; }
.preview-output h6 { font-size: 0.9rem; }

.preview-output p {
  margin: var(--space-2) 0;
}

.preview-output code {
  font-family: var(--font-mono);
  background: var(--color-bg);
  color: var(--color-accent);
  padding: 0.2rem 0.4rem;
  border-radius: var(--radius-sm);
  font-size: 0.85em;
}

.preview-output pre {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: var(--space-3);
  overflow-x: auto;
  margin: var(--space-3) 0;
}

.preview-output pre code {
  background: transparent;
  padding: 0;
}

.preview-output ul,
.preview-output ol {
  margin: var(--space-2) 0;
  padding-left: var(--space-5);
}

.preview-output li {
  margin: var(--space-1) 0;
}

.preview-output blockquote {
  border-left: 4px solid var(--color-accent);
  padding-left: var(--space-3);
  margin: var(--space-3) 0;
  color: var(--color-text-muted);
  font-style: italic;
}

.preview-output table {
  width: 100%;
  border-collapse: collapse;
  margin: var(--space-3) 0;