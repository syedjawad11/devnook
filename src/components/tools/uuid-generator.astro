---
// UUID v4 Generator component - client-side only
---
<div class="tool-container" id="tool-uuid-generator">
  <div class="tool-header">
    <h2>UUID v4 Generator</h2>
    <p class="tool-desc">Generate cryptographically secure UUID v4 identifiers instantly in your browser.</p>
  </div>

  <div class="tool-body">
    <div class="tool-controls">
      <div class="control-group">
        <label for="uuid-count">Number of UUIDs</label>
        <input 
          type="number" 
          id="uuid-count" 
          min="1" 
          max="100" 
          value="1"
          aria-label="Number of UUIDs to generate"
        />
      </div>

      <div class="control-group checkbox-group">
        <label>
          <input 
            type="checkbox" 
            id="uuid-uppercase"
            aria-label="Generate UUIDs in uppercase format"
          />
          <span>Uppercase</span>
        </label>
      </div>

      <div class="button-group">
        <button 
          id="generate-btn" 
          class="primary-btn"
          aria-label="Generate UUID identifiers"
        >
          Generate
        </button>
        <button 
          id="copy-all-btn" 
          class="secondary-btn"
          aria-label="Copy all generated UUIDs to clipboard"
          disabled
        >
          Copy All
        </button>
        <button 
          id="clear-btn" 
          class="secondary-btn"
          aria-label="Clear all generated UUIDs"
          disabled
        >
          Clear
        </button>
      </div>
    </div>

    <div class="output-section">
      <div class="output-header">
        <label for="uuid-output">Generated UUIDs</label>
        <span id="uuid-count-display" class="count-display">0 UUIDs</span>
      </div>
      <div id="uuid-output" class="uuid-list" role="list"></div>
    </div>
  </div>

  <div class="tool-status" id="status-message" aria-live="polite"></div>
</div>

<script>
(function() {
  const countInput = document.getElementById('uuid-count');
  if (!countInput) return;
  const uppercaseCheckbox = document.getElementById('uuid-uppercase');
  const generateBtn = document.getElementById('generate-btn');
  const copyAllBtn = document.getElementById('copy-all-btn');
  const clearBtn = document.getElementById('clear-btn');
  const outputContainer = document.getElementById('uuid-output');
  const statusMessage = document.getElementById('status-message');
  const countDisplay = document.getElementById('uuid-count-display');

  let generatedUUIDs = [];

  function generateUUIDv4() {
    if (typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function') {
      return crypto.randomUUID();
    }

    if (typeof crypto !== 'undefined' && crypto.getRandomValues) {
      const bytes = new Uint8Array(16);
      crypto.getRandomValues(bytes);
      
      bytes[6] = (bytes[6] & 0x0f) | 0x40;
      bytes[8] = (bytes[8] & 0x3f) | 0x80;
      
      const hex = Array.from(bytes).map(b => b.toString(16).padStart(2, '0')).join('');
      return `${hex.slice(0,8)}-${hex.slice(8,12)}-${hex.slice(12,16)}-${hex.slice(16,20)}-${hex.slice(20,32)}`;
    }

    throw new Error('Cryptographic random number generation not supported in this browser.');
  }

  function showStatus(message, isError = false) {
    statusMessage.textContent = message;
    statusMessage.className = 'tool-status' + (isError ? ' error' : ' success');
    statusMessage.style.display = 'block';
    
    if (!isError) {
      setTimeout(() => {
        statusMessage.style.display = 'none';
      }, 2000);
    }
  }

  function updateCountDisplay() {
    const count = generatedUUIDs.length;
    countDisplay.textContent = `${count} UUID${count !== 1 ? 's' : ''}`;
  }

  function renderUUIDs() {
    outputContainer.innerHTML = '';
    
    if (generatedUUIDs.length === 0) {
      outputContainer.innerHTML = '<div class="empty-state">No UUIDs generated yet. Click Generate to create UUIDs.</div>';
      copyAllBtn.disabled = true;
      clearBtn.disabled = true;
      return;
    }

    generatedUUIDs.forEach((uuid, index) => {
      const uuidItem = document.createElement('div');
      uuidItem.className = 'uuid-item';
      uuidItem.setAttribute('role', 'listitem');
      
      const uuidText = document.createElement('code');
      uuidText.className = 'uuid-text';
      uuidText.textContent = uuid;
      
      const copyBtn = document.createElement('button');
      copyBtn.className = 'copy-btn';
      copyBtn.textContent = 'Copy';
      copyBtn.setAttribute('aria-label', `Copy UUID ${index + 1} to clipboard`);
      copyBtn.addEventListener('click', () => copyIndividualUUID(uuid, copyBtn));
      
      uuidItem.appendChild(uuidText);
      uuidItem.appendChild(copyBtn);
      outputContainer.appendChild(uuidItem);
    });

    copyAllBtn.disabled = false;
    clearBtn.disabled = false;
  }

  function handleGenerate() {
    try {
      const count = parseInt(countInput.value, 10);
      
      if (isNaN(count) || count < 1 || count > 100) {
        showStatus('Please enter a number between 1 and 100.', true);
        return;
      }

      const isUppercase = uppercaseCheckbox.checked;
      const newUUIDs = [];

      for (let i = 0; i < count; i++) {
        let uuid = generateUUIDv4();
        if (isUppercase) {
          uuid = uuid.toUpperCase();
        }
        newUUIDs.push(uuid);
      }

      generatedUUIDs = newUUIDs;
      renderUUIDs();
      updateCountDisplay();
      showStatus(`Generated ${count} UUID${count !== 1 ? 's' : ''} successfully.`);
    } catch (error) {
      showStatus('Failed to generate UUIDs. Your browser may not support cryptographic random generation.', true);
    }
  }

  async function copyIndividualUUID(uuid, button) {
    try {
      await navigator.clipboard.writeText(uuid);
      const originalText = button.textContent;
      button.textContent = 'Copied!';
      button.classList.add('copied');
      
      setTimeout(() => {
        button.textContent = originalText;
        button.classList.remove('copied');
      }, 2000);
    } catch (error) {
      showStatus('Failed to copy UUID to clipboard.', true);
    }
  }

  async function handleCopyAll() {
    if (generatedUUIDs.length === 0) return;

    try {
      const allUUIDs = generatedUUIDs.join('\n');
      await navigator.clipboard.writeText(allUUIDs);
      
      const originalText = copyAllBtn.textContent;
      copyAllBtn.textContent = 'Copied!';
      copyAllBtn.classList.add('copied');
      
      setTimeout(() => {
        copyAllBtn.textContent = originalText;
        copyAllBtn.classList.remove('copied');
      }, 2000);
      
      showStatus(`Copied ${generatedUUIDs.length} UUID${generatedUUIDs.length !== 1 ? 's' : ''} to clipboard.`);
    } catch (error) {
      showStatus('Failed to copy UUIDs to clipboard.', true);
    }
  }

  function handleClear() {
    generatedUUIDs = [];
    renderUUIDs();
    updateCountDisplay();
    showStatus('Cleared all UUIDs.');
  }

  generateBtn.addEventListener('click', handleGenerate);
  copyAllBtn.addEventListener('click', handleCopyAll);
  clearBtn.addEventListener('click', handleClear);
  
  countInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      handleGenerate();
    }
  });

  renderUUIDs();
  updateCountDisplay();
})();
</script>

<style>
.tool-container {
  max-width: 900px;
  margin: 0 auto;
  padding: var(--space-6);
}

.tool-header {
  margin-bottom: var(--space-6);
}

.tool-header h2 {
  font-size: 2rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0 0 var(--space-2) 0;
}

.tool-desc {
  color: var(--color-text-muted);
  margin: 0;
  font-size: 1rem;
}

.tool-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.tool-controls {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.control-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.control-group label {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text);
}

.control-group input[type="number"] {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: var(--space-2) var(--space-3);
  color: var(--color-text);
  font-family: var(--font-body);
  font-size: 1rem;
  max-width: 150px;
}

.control-group input[type="number"]:focus {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}

.checkbox-group label {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  cursor: pointer;
  flex-direction: row;
}

.checkbox-group input[type="checkbox"] {
  width: 18px;
  height: 18px;
  cursor: pointer;
  accent-color: var(--color-accent);
}

.button-group {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
}

button {
  padding: var(--space-3) var(--space-5);
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  border: none;
}

.primary-btn {
  background: var(--color-accent);
  color: var(--color-bg);
}

.primary-btn:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

.secondary-btn {
  background: var(--color-surface);
  color: var(--color-text);
  border: 1px solid var(--color-border);
}

.secondary-btn:hover:not(:disabled) {
  background: var(--color-border);
}

.secondary-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.secondary-btn.copied {
  background: var(--color-accent);
  color: var(--color-bg);
  border-color: var(--color-accent);
}

.output-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.output-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.output-header label {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text);
}

.count-display {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  font-family: var(--font-mono);
}

.uuid-list {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-4);
  min-height: 200px;
  max-height: 500px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--color-text-muted);
  font-size: 0.875rem;
  text-align: center;
  padding: var(--space-6);
}

.uuid-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
}

.uuid-text {
  font-family: var(--font-mono);
  font-size: 0.875rem;
  color: var(--color-accent);
  flex: 1;
  overflow-x: auto;
  white-space: nowrap;
}

.copy-btn {
  padding: var(--space-2) var(--space-3);
  background: var(--color-surface);
  color: var(--color-text);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: 0.75rem;
  white-space: nowrap;
}

.copy-btn:hover {
  background: var(--color-border);
}

.copy-btn.copied {
  background: var(--color-accent);
  color: var(--color-bg);
  border-color: var(--color-accent);
}

.tool-status {
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
  display: none;
  margin-top: var(--space-4);
}

.tool-status.success {
  background: var(--color-green-light);
  color: var(--color-accent);
  border: 1px solid var(--color-accent);
}

.tool-status.error {
  background: var(--color-coral-light);
  color: var(--color-coral);
  border: 1px solid var(--color-coral);
}

@media (