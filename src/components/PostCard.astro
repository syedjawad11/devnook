---
interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  date: string;
  category?: string;
}

const { title, description, href, tags = [], date, category } = Astro.props;

const CATEGORY_STYLES: Record<string, { color: string; bg: string; label: string }> = {
  comparison: { color: 'var(--color-accent)', bg: 'var(--color-accent-light)', label: 'Comparison' },
  tutorial:   { color: 'var(--color-green)',  bg: 'var(--color-green-light)',  label: 'Tutorial' },
  ai:         { color: 'var(--color-purple)', bg: 'var(--color-purple-light)', label: 'AI' },
  'how-to':   { color: 'var(--color-amber)',  bg: 'var(--color-amber-light)',  label: 'How-to' },
  guide:      { color: 'var(--color-accent)', bg: 'var(--color-accent-light)', label: 'Guide' },
  cheatsheet: { color: 'var(--color-coral)',  bg: 'var(--color-coral-light)',  label: 'Cheatsheet' },
  languages:  { color: 'var(--color-purple)', bg: 'var(--color-purple-light)', label: 'Language' },
  blog:       { color: 'var(--color-accent)', bg: 'var(--color-accent-light)', label: 'Blog' },
};

function deriveCategory(cat: string | undefined, tagList: string[]): { color: string; bg: string; label: string } | null {
  if (cat && CATEGORY_STYLES[cat]) return CATEGORY_STYLES[cat];

  const joined = [cat, ...tagList].filter(Boolean).join(' ').toLowerCase();
  if (/compar|vs\b/.test(joined)) return CATEGORY_STYLES.comparison;
  if (/\bai\b|llm|claude|gpt|gemini/.test(joined)) return CATEGORY_STYLES.ai;
  if (/tutorial|getting started|learn/.test(joined)) return CATEGORY_STYLES.tutorial;
  if (/how\s*to|recipe/.test(joined)) return CATEGORY_STYLES['how-to'];
  if (/cheat\s*sheet/.test(joined)) return CATEGORY_STYLES.cheatsheet;

  if (tagList.length > 0) {
    return {
      color: 'var(--color-accent)',
      bg: 'var(--color-accent-light)',
      label: tagList[0].charAt(0).toUpperCase() + tagList[0].slice(1).replace(/-/g, ' '),
    };
  }
  return null;
}

const badge = deriveCategory(category, tags);

const formatDate = (dateString: string): string => {
  const d = new Date(dateString);
  if (isNaN(d.getTime())) return '';
  const month = d.toLocaleDateString('en-US', { month: 'short' });
  const year = d.getFullYear();
  return `${month} ${year}`;
};

const formattedDate = formatDate(date);
---

<article class="post-card">
  <div class="post-meta">
    {badge && (
      <span class="post-cat" style={`background:${badge.bg}; color:${badge.color}`}>{badge.label}</span>
    )}
    {formattedDate && <span class="post-date">{formattedDate}</span>}
  </div>

  <h3 class="post-card__title">
    <a href={href}>{title}</a>
  </h3>

  <p class="post-card__description">{description}</p>
</article>

<style>
  .post-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .post-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .post-cat {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .post-date {
    font-size: 12px;
    color: var(--color-text-faint);
    margin-left: auto;
    font-family: var(--font-mono);
  }

  .post-card__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.4;
  }

  .post-card__title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .post-card__title a:hover {
    color: var(--color-accent);
  }

  .post-card__description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
